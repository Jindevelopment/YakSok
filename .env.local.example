# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq AI (console.groq.com)
GROQ_API_KEY=

# 식약처 공공데이터 API (data.go.kr)
MFDS_API_KEY=
MFDS_EASY_API_KEY=
# 낱알식별 API (모양 검색용) — data.go.kr에서 "의약품 낱알식별 정보 서비스" 별도 신청 필요
MFDS_GRAIN_API_KEY=

# 네이버 지도 API (console.ncloud.com — Application 등록 후 "Maps" 서비스 선택)
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=

# 네이버 검색 API (developers.naver.com — "지역" 검색 API 신청)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
